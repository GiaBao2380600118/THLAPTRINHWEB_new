    ViewData["Title"] = "Đăng xuất";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <h1 class="text-primary mb-3">@ViewData["Title"]</h1>
        <p class="lead text-muted">Bạn đã đăng xuất thành công khỏi hệ thống.</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary rounded-pill px-4 mt-3">Quay lại Trang chủ</a>
    </div>
</div>
