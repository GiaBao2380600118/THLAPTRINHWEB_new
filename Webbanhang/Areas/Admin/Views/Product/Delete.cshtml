@model Webbanhang.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h4 class="fw-bold text-danger mb-4">Xác nhận xóa sản phẩm</h4>
            <div class="alert alert-warning rounded-3">
                ⚠️ Hành động này không thể hoàn tác. Bạn có chắc chắn muốn xóa sản phẩm này không?
            </div>
            
            <div class="row g-4 mt-2 align-items-center">
                <div class="col-md-4 text-center">
                    <img src="@(Model.ImageUrl ?? "/images/no-image.svg")" class="img-fluid rounded-4 shadow-sm" style="max-height: 180px; object-fit: cover;" alt="@Model.Name" />
                </div>
                <div class="col-md-8">
                    <h3 class="fw-bold text-slate-800">@Model.Name</h3>
                    <p class="fs-4 fw-semibold text-primary">@Model.Price.ToString("N0") đ</p>
                    <p class="text-muted small">@Model.Description</p>
                </div>
            </div>

            <form asp-area="Admin" asp-controller="Product" asp-action="DeleteConfirmed" method="post" class="mt-4 border-top pt-3">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger rounded-pill px-4 me-2">Xác nhận xóa</button>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy bỏ</a>
            </form>
        </div>
    </div>
</div>
